{
    "name": "rafael/omiephpsdk",
    "description": "Biblioteca PHP para o uso com a api da OMIE",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Rafael\\Omiephpsdk\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Rafael Paulino"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "illuminate/config": "^12.52",
        "illuminate/container": "^12.52",
        "illuminate/filesystem": "^12.52",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "pestphp/pest": "^4.4"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
